     1	//! REPL agent construction — threads the config, permission, tools,
     2	//! and UI widgets into a ready-to-run `Agent<a>`.
     3	//!
     4	//! Kept separate from repl.rs so the turn loop there can focus on
     5	//! dispatch instead of wiring. `build_agent` is the only public entry;
     6	//! everything it returns is standard `metis_core` types.
     7	
     8	use std::io::{self, Write};
     9	use std::path::Path;
    10	use std::sync::{Arc, Mutex};
    11	
    12	use anyhow::{Context, Result};
    13	use crossterm::cursor;
    14	use crossterm::event::{self, Event, KeyCode, KeyEventKind};
    15	use crossterm::terminal::{disable_raw_mode, enable_raw_mode, Clear, ClearType};
    16	use metis_api::{ChatProvider, StreamEvent};
    17	use metis_core::{Agent, AgentConfig, Permission, SessionStore, ToolContext, ToolRegistry};
    18	
    19	use crate::agent_spawner;
    20	use crate::markdown::MdRenderer;
    21	
    22	use super::format::{canonical_tool_name, format_tool_call, trim_tool_preview};
    23	#[cfg(unix)]
    24	use super::overlay::InputOverlay;
    25	use super::spinner::ThinkingSpinner;
    26	
    27	/// Builds an agent bound to a session. If `session` is `Some`, the
    28	/// agent adopts it as-is (used by `/fork` to continue on a just-copied
    29	/// branch). If `None`, a fresh session id is minted — the behaviour
    30	/// the REPL entry point and `/clear` both want.
    31	#[allow(clippy::too_many_arguments)]
    32	pub(super) fn build_agent<'a>(
    33	    client: &'a dyn ChatProvider,
    34	    registry: &'a ToolRegistry,
    35	    workspace: &Path,
    36	    config: AgentConfig,
    37	    permission: Arc<dyn Permission>,
    38	    session: Option<SessionStore>,
    39	    plan_state: Option<Arc<Mutex<metis_core::PlanState>>>,
    40	    md: Arc<Mutex<MdRenderer>>,
    41	    spawner_client: Arc<dyn ChatProvider>,
    42	    spawner_registry: Arc<ToolRegistry>,
    43	    sandbox: metis_core::SandboxMode,
    44	    spinner: Arc<ThinkingSpinner>,
    45	    #[cfg(unix)] overlay: Arc<InputOverlay>,
    46	    #[cfg(feature = "ctx")] blob_handles: Option<(
    47	        Arc<metis_core::BlobStore>,
    48	        Arc<metis_core::BlobIndex>,
    49	    )>,
    50	) -> Result<Agent<'a>> {
    51	    let session = match session {
    52	        Some(s) => s,
    53	        None => {
    54	            let id = SessionStore::new_id();
    55	            let s = SessionStore::open(workspace, &id).context("could not open REPL session")?;
    56	            eprintln!("\x1b[1;32m[metis] repl session={id}\x1b[0m");
    57	            s
    58	        }
    59	    };
    60	    let mut ctx = ToolContext::new(workspace.to_path_buf()).with_user_input(std::sync::Arc::new(
    61	        |_question, options| {
    62	            // Temporarily restore echo so the user can see what they type.
    63	            #[cfg(unix)]
    64	            let saved = {
    65	                unsafe {
    66	                    let mut t: libc::termios = std::mem::zeroed();
    67	                    if libc::tcgetattr(libc::STDIN_FILENO, &mut t) == 0 {
    68	                        let s = t;
    69	                        t.c_lflag |= libc::ECHO;
    70	                        libc::tcsetattr(libc::STDIN_FILENO, libc::TCSANOW, &t);
    71	                        Some(s)
    72	                    } else {
    73	                        None
    74	                    }
    75	                }
    76	            };
    77	
    78	            eprint!("  \x1b[38;2;122;240;227m>\x1b[0m ");
    79	            let _ = std::io::stderr().flush();
    80	            let mut line = String::new();
    81	            match std::io::stdin().read_line(&mut line) {
    82	                Ok(0) | Err(_) => {
    83	                    #[cfg(unix)]
    84	                    if let Some(t) = saved {
    85	                        unsafe {
    86	                            libc::tcsetattr(libc::STDIN_FILENO, libc::TCSANOW, &t);
    87	                        }
    88	                    }
    89	                    None
    90	                }
    91	                Ok(_) => {
    92	                    #[cfg(unix)]
    93	                    if let Some(t) = saved {
    94	                        unsafe {
    95	                            libc::tcsetattr(libc::STDIN_FILENO, libc::TCSANOW, &t);
    96	                        }
    97	                    }
    98	                    let trimmed = line.trim().to_string();
    99	                    if trimmed.is_empty() {
   100	                        return None;
   101	                    }
   102	                    // If options exist and user typed a number, resolve it.
   103	                    if !options.is_empty() {
   104	                        if let Ok(n) = trimmed.parse::<usize>() {
   105	                            if n >= 1 && n <= options.len() {
   106	                                return Some(options[n - 1].clone());
   107	                            }
   108	                        }
   109	                    }
   110	                    Some(trimmed)
   111	                }
   112	            }
   113	        },
   114	    ));
   115	    if let Some(ps) = plan_state {
   116	        ctx = ctx.with_plan_state(ps);
   117	    }
   118	    ctx.bash.sandbox = sandbox;
   119	    let hooks = metis_core::load_hooks(workspace);
   120	    ctx = ctx.with_hooks(hooks);
   121	
   122	    // Wire the shared agent-spawner so `agent` and `parallel_agents` tools
   123	    // can fan out work onto subagents. See `crate::agent_spawner` for the
   124	    // single source of truth shared by REPL/TUI/one-shot/IDE.
   125	    let spawner = agent_spawner::build(
   126	        Arc::clone(&spawner_client),
   127	        Arc::clone(&spawner_registry),
   128	        workspace,
   129	        config.clone(),
   130	        Arc::clone(&permission),
   131	        ctx.background_agents.clone(),
   132	    );
   133	    ctx = ctx.with_agent_spawner(spawner);
   134	
   135	    const SR: &str = "\x1b[0m";
   136	
   137	    let mut agent = Agent::new(client, registry, ctx, config)
   138	        .with_permission(permission)
   139	        .with_guardrail(metis_core::guardrail::load_default(workspace))
   140	        .with_session(session);
   141	    #[cfg(feature = "ctx")]
   142	    if let Some((store, index)) = blob_handles {
   143	        agent = agent.with_blob_handles(store, index);
   144	    }
   145	    Ok(agent
   146	        .with_stream_callback({
   147	            let md = Arc::clone(&md);
   148	            let spinner = Arc::clone(&spinner);
   149	            #[cfg(unix)] let overlay = Arc::clone(&overlay);
   150	            move |event| {
   151	                spinner.note_event();
   152	                match event {
   153	                StreamEvent::TextDelta(text) => {
   154	                    #[cfg(unix)] overlay.before_output();
   155	                    // Hold term_lock while writing to stdout so the overlay
   156	                    // thread's stderr writes cannot interleave and corrupt
   157	                    // the terminal cursor / scroll region.
   158	                    #[cfg(unix)] let _term_lk = overlay.term_lock.lock().unwrap();
   159	                    if let Ok(mut r) = md.lock() {
   160	                        r.push(&text);
   161	                    }
   162	                }
   163	                StreamEvent::ThinkingDelta(_text) => {}
   164	                StreamEvent::ToolCall {
   165	                    name,
   166	                    arguments_preview,
   167	                } => {
   168	                    if let Ok(mut r) = md.lock() {
   169	                        r.finish();
   170	                    }
   171	                    let _ = std::io::stdout().flush();
   172	                    #[cfg(unix)] overlay.before_output();
   173	                    let canonical = canonical_tool_name(&name);
   174	                    let arg = format_tool_call(&name, &arguments_preview);
   175	                    eprintln!("\x1b[38;2;220;220;210m●{SR} \x1b[38;2;220;220;210m{canonical}{SR}\x1b[2m  {arg}{SR}");
   176	                }
   177	                StreamEvent::ToolResult {
   178	                    name: _,
   179	                    preview,
   180	                    is_error,
   181	                } => {
   182	                    let trimmed_preview = trim_tool_preview(&preview);
   183	                    #[cfg(unix)] overlay.before_output();
   184	                    // Drop empty previews entirely — `[stdout]` with no
   185	                    // body should not produce a hanging `⎿` line.
   186	                    if trimmed_preview.is_empty() {
   187	                        #[cfg(unix)] overlay.after_output();
   188	                    } else if is_error {
   189	                        eprintln!("  \x1b[31m⎿ {trimmed_preview}{SR}");
   190	                        #[cfg(unix)] overlay.after_output();
   191	                    } else {
   192	                        eprintln!("  \x1b[2m⎿ {trimmed_preview}{SR}");
   193	                        #[cfg(unix)] overlay.after_output();
   194	                    }
   195	                }
   196	                StreamEvent::Usage(_) => {}
   197	                StreamEvent::RetryReset => {
   198	                    if let Ok(mut r) = md.lock() {
   199	                        // Preserve the provider-specific dedup setting
   200	                        // across a retry — rebuilding the renderer from
   201	                        // scratch would re-enable long-line dedup on
   202	                        // z.ai / GLM sessions and swallow verbatim
   203	                        // repeated lines again.
   204	                        let keep_dedup = r.dedup_enabled();
   205	                        *r = crate::markdown::MdRenderer::new();
   206	                        r.set_dedup_enabled(keep_dedup);
   207	                    }
   208	                    #[cfg(unix)] overlay.before_output();
   209	                    eprint!("\r\x1b[2K\x1b[2m(retrying…){SR}\r\x1b[2K");
   210	                    let _ = std::io::stderr().flush();
   211	                }
   212	                }
   213	            }
   214	        }))
   215	}
   216	
   217	/// Show an interactive terminal menu. Renders the prompt and a numbered
   218	/// list of options; the user navigates with ↑/↓ and confirms with Enter.
   219	/// Returns the selected option text, or `io::Error` if the terminal
   220	/// is not available or raw-mode fails.
   221	pub fn ask_user(prompt: &str, options: &[&str]) -> io::Result<String> {
   222	    let mut stdout = io::stdout();
   223	    enable_raw_mode()?;
   224	
   225	    let mut selected = 0usize;
   226	
   227	    loop {
   228	        // ── render ──────────────────────────────────────────────
   229	        write!(stdout, "{}\r\n", prompt)?;
   230	        for (i, opt) in options.iter().enumerate() {
   231	            if i == selected {
   232	                write!(stdout, "\x1b[7m {}. {} \x1b[0m\r\n", i + 1, opt)?;
   233	            } else {
   234	                write!(stdout, " {}. {}\r\n", i + 1, opt)?;
   235	            }
   236	        }
   237	        // Move cursor back up so we can redraw on the next iteration.
   238	        let lines = options.len() + 1; // prompt + one per option
   239	        write!(stdout, "{}", cursor::MoveUp(lines as u16))?;
   240	        stdout.flush()?;
   241	
   242	        // ── input ────────────────────────────────────────────────
   243	        match event::read()? {
   244	            Event::Key(kv) if kv.kind == KeyEventKind::Press => match kv.code {
   245	                KeyCode::Up | KeyCode::Char('k') => {
   246	                    selected = selected.saturating_sub(1);
   247	                }
   248	                KeyCode::Down | KeyCode::Char('j') => {
   249	                    selected = selected.saturating_add(1).min(options.len() - 1);
   250	                }
   251	                KeyCode::Enter => {
   252	                    // Clear the rendered menu.
   253	                    let clear_lines = options.len() + 1;
   254	                    write!(stdout, "{}", cursor::MoveUp(clear_lines as u16))?;
   255	                    for _ in 0..clear_lines {
   256	                        write!(stdout, "{}", Clear(ClearType::CurrentLine))?;
   257	                        write!(stdout, "{}", cursor::MoveDown(1))?;
   258	                    }
   259	                    write!(stdout, "{}", cursor::MoveUp(clear_lines as u16))?;
   260	                    stdout.flush()?;
   261	                    disable_raw_mode()?;
   262	                    return Ok(options[selected].to_string());
   263	                }
   264	                KeyCode::Esc | KeyCode::Char('q') => {
   265	                    disable_raw_mode()?;
   266	                    return Err(io::Error::new(io::ErrorKind::Interrupted, "cancelled"));
   267	                }
   268	                _ => {}
   269	            },
   270	            _ => {}
   271	        }
   272	    }
   273	}
