                     if let Ok(mut r) = md.lock() {
                         r.finish();
                     }
                     let _ = std::io::stdout().flush();
                     #[cfg(unix)] overlay.before_output();
                     let canonical = canonical_tool_name(&name);
                     let arg = format_tool_call(&name, &arguments_preview);
