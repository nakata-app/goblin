{
  "name": "goblin-ai",
  "displayName": "Goblin AI",
  "description": "Goblin AI assistant sidebar for VS Code",
  "version": "0.1.0",
  "publisher": "goblin",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "goblin-sidebar",
          "title": "Goblin",
          "icon": "media/goblin.svg"
        }
      ]
    },
    "views": {
      "goblin-sidebar": [
        {
          "type": "webview",
          "id": "goblin.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "goblin.clearChat",
        "title": "Clear Chat",
        "category": "Goblin",
        "icon": "$(trash)"
      },
      {
        "command": "goblin.reconnect",
        "title": "Reconnect",
        "category": "Goblin",
        "icon": "$(refresh)"
      },
      {
        "command": "goblin.sendSelection",
        "title": "Ask Goblin About Selection",
        "category": "Goblin"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "goblin.clearChat",
          "when": "view == goblin.chatView",
          "group": "navigation"
        },
        {
          "command": "goblin.reconnect",
          "when": "view == goblin.chatView",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "goblin.sendSelection",
          "when": "editorHasSelection",
          "group": "goblin"
        }
      ]
    },
    "keybindings": [
      {
        "command": "goblin.sendSelection",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g",
        "when": "editorHasSelection"
      }
    ],
    "configuration": {
      "title": "Goblin",
      "properties": {
        "goblin.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Goblin HTTP API host"
        },
        "goblin.port": {
          "type": "number",
          "default": 1789,
          "description": "Goblin HTTP API port (matches http.bind in ~/.goblin/config.toml)"
        },
        "goblin.token": {
          "type": "string",
          "default": "",
          "description": "Goblin HTTP API bearer token (matches http.token in ~/.goblin/config.toml)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/vscode": "^1.85.0",
    "typescript": "5.3"
  }
}
